# API Configuration
VITE_API_BASE_URL=https://api.yourdomain.com

# Optional: For encryption service (if using local encryption)
VITE_ENCRYPTION_KEY=your-secret-encryption-key-here

# Optional: Enable debug mode
VITE_DEBUG=false

# Optional: API timeout (milliseconds)
VITE_API_TIMEOUT=30000

# Optional: Token expiration time (milliseconds, default 24h)
VITE_TOKEN_EXPIRATION=86400000
